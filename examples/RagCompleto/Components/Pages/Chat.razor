@page "/"
@rendermode InteractiveServer
@inject RagClient RagClient

@*
    Chat multi-turno con dos modos:
      • RAG    — RagClient.StartChat(domain, profile): sesión con memoria real
                 (el enrutado se resuelve una vez, en el primer turno, y se
                 reutiliza en los siguientes).
      • Agente — RagClient.AskAgentStreamAsync(...) con AgentToolScope.SearchOnly:
                 el modelo decide si busca o no; se ve la actividad de la
                 herramienta (🔍 usando… / ✓ lista) y la respuesta llega en
                 streaming igual que en modo RAG, aunque sin memoria entre
                 turnos (no hay variante de sesión agéntica hoy).

    El dominio se puede fijar o dejar en "auto" (el tier-2 enruta). La gestión
    de documentos/perfiles/guardarails vive en el panel de administración
    (/rag-admin, RagKit.Dashboard) — esta página es solo la experiencia de
    consumidor.
*@

<PageTitle>RagCompleto — Chat</PageTitle>

<section class="controls">
    <label>
        Dominio
        <select @bind="_domain" @bind:after="ResetConversation">
            <option value="">(auto — el tier-2 enruta)</option>
            <option value="@Domains.Fiscal">fiscal</option>
            <option value="@Domains.Rrhh">rrhh</option>
            <option value="@Domains.Legal">legal</option>
        </select>
    </label>
    <label>
        Modo
        <select @bind="_mode" @bind:after="ResetConversation">
            <option value="RAG">RAG (con memoria)</option>
            <option value="Agente">Agente (una tool por pregunta, sin memoria)</option>
        </select>
    </label>
    @if (_resolvedDomain is not null)
    {
        <span class="chip">enrutado a: <b>@_resolvedDomain</b>@(_resolvedProfile is null ? "" : $" · {_resolvedProfile}")</span>
    }
</section>

<div class="messages">
    @if (_msgs.Count == 0)
    {
        <div class="empty">Pregunta algo sobre fiscal, rrhh o legal 👇 (ingiere documentos primero en «Ingesta»)</div>
    }
    @foreach (var m in _msgs)
    {
        <div class="msg @m.Role">
            @if (m.Activities.Count > 0)
            {
                <div class="activity">
                    @foreach (var a in m.Activities)
                    {
                        <span class="tool">@(a.Done ? "✓" : "🔍") @a.Name@(a.Done ? " listo" : "…")</span>
                    }
                </div>
            }
            <div class="bubble">@(m.Text.Length == 0 ? "…" : m.Text)</div>
            @if (m.Citations.Count > 0)
            {
                <div class="cites">
                    @foreach (var c in m.Citations.GroupBy(x => x.Source).Select(g => g.First()))
                    {
                        <span class="cite" title="@c.Snippet">[@c.Source]</span>
                    }
                </div>
            }
        </div>
    }
</div>

<div class="ask">
    <input @bind="_question" @bind:event="oninput" @onkeydown="OnKey"
           placeholder="Escribe tu pregunta…" disabled="@_asking" />
    <button class="primary" disabled="@_asking" @onclick="Ask">@(_asking ? "…" : "Enviar")</button>
</div>

@code {
    string _domain = "";
    string _mode = "RAG";
    ChatSession? _session;
    string? _resolvedDomain;
    string? _resolvedProfile;

    readonly List<Msg> _msgs = new();
    string _question = "";
    bool _asking;

    sealed class Msg
    {
        public required string Role { get; init; }
        public string Text { get; set; } = "";
        public IReadOnlyList<Citation> Citations { get; set; } = Array.Empty<Citation>();
        public List<ToolActivity> Activities { get; } = new();
    }

    /// <summary>One tool call shown in the "Agente" mode transcript: pending
    /// (🔍 usando…) until its matching <c>ToolCallFinished</c> event arrives (✓ lista).</summary>
    sealed class ToolActivity
    {
        public required string Name { get; init; }
        public bool Done { get; set; }
    }

    void ResetConversation()
    {
        _session = null;
        _resolvedDomain = null;
        _resolvedProfile = null;
        _msgs.Clear();
    }

    async Task OnKey(KeyboardEventArgs e) { if (e.Key == "Enter") await Ask(); }

    async Task Ask()
    {
        var q = _question.Trim();
        if (q.Length == 0 || _asking) return;
        _asking = true;
        _question = "";
        _msgs.Add(new Msg { Role = "user", Text = q });
        var answer = new Msg { Role = "assistant" };
        _msgs.Add(answer);

        try
        {
            var domainArg = string.IsNullOrEmpty(_domain) ? null : _domain;
            if (_mode == "Agente")
            {
                // Streameado pero sin memoria entre turnos (no hay ChatSession agéntica
                // hoy): el modelo decide si busca, se ve la actividad de la herramienta,
                // y la respuesta final llega token a token igual que en modo RAG.
                var stream = await RagClient.AskAgentStreamAsync(q, domain: domainArg, tools: AgentToolScope.SearchOnly);
                await foreach (var e in stream.Events)
                {
                    switch (e.Kind)
                    {
                        case AgentStreamEventKind.ToolCallStarted:
                            answer.Activities.Add(new ToolActivity { Name = e.ToolName! });
                            break;
                        case AgentStreamEventKind.ToolCallFinished:
                            var pending = answer.Activities.LastOrDefault(a => a.Name == e.ToolName && !a.Done);
                            if (pending is not null) pending.Done = true;
                            break;
                        case AgentStreamEventKind.Citations:
                            answer.Citations = e.Citations!;
                            break;
                        case AgentStreamEventKind.Token:
                            answer.Text += e.Token;
                            break;
                    }
                    StateHasChanged();
                }
            }
            else
            {
                _session ??= RagClient.StartChat(domain: domainArg);
                var stream = await _session.AskStreamAsync(q);
                answer.Citations = stream.Citations;
                await foreach (var token in stream.Tokens)
                {
                    answer.Text += token;
                    StateHasChanged();
                }
                _resolvedDomain = _session.Domain;
                _resolvedProfile = _session.Profile;
            }
        }
        catch (Exception ex) { answer.Text = "⚠ " + ex.Message; }
        _asking = false;
    }
}
